# Robot named poses for luggage loading (joint targets in radians).
# Copy to robot_poses.yaml and tune for camera field of view.

poses:
  observe:
    group: elfin_arm
    joints:
      - elfin_joint1
      - elfin_joint2
      - elfin_joint3
      - elfin_joint4
      - elfin_joint5
      - elfin_joint6
    # Tuned via pose_tune_moveit.launch — camera RGB facing ground/luggage.
    values: [-2.7130, -1.3263, -1.0965, 3.9564, -4.6598, 0.4522]
    tolerance: 0.02

defaults:
  observe_pose: observe
  planning_time: 10.0
  max_velocity_scaling: 0.3
  max_acceleration_scaling: 0.3

meta:
  name: robot_poses_v1
  version: 0.2.0
